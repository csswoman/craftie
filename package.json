{
  "name": "color-tool",
  "version": "1.0.0",
  "private": true,
  "description": "Craftie — color palettes, WCAG validation, and font pairings",
  "directories": {
    "doc": "docs",
    "lib": "lib"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:component-size": "node scripts/check-component-size.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm lint && pnpm check:component-size && pnpm typecheck && pnpm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "culori": "^4.0.2",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "ntcjs": "^1.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/culori": "^4.0.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
